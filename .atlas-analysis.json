{
  "projectType": "cli-tool",
  "projectName": "Proletario Parásito Podcast Parser",
  "projectDescription": "A .NET 8 CLI tool that fetches, parses, and summarizes episode data from the Proletario y Parásito podcast RSS feed",
  "theme": "aspen",
  "primaryColor": "#040404",
  "lightColor": "#1484fc",
  "darkColor": "#82beef",
  "navigation": {
    "groups": [
      {
        "group": "Get Started",
        "pages": [
          "introduction",
          "installation",
          "quickstart"
        ]
      },
      {
        "group": "Architecture",
        "pages": [
          "architecture/overview",
          "architecture/pipeline",
          "architecture/parsing-logic"
        ]
      },
      {
        "group": "API Reference",
        "pages": [
          "api/models",
          "api/services",
          "api/rss-feed-service",
