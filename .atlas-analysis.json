          "examples/title-patterns",
          "examples/simpsons-references"
        ]
      }
    ]
  },
  "keyFeatures": [
    "RSS feed fetching and XML parsing",
    "Episode title parsing with regex patterns",
    "Guest name extraction from episode titles",
    "Simpsons episode reference extraction",
    "HTML tag stripping and entity decoding",
    "iTunes duration conversion to seconds",
    "Color-coded console output"
  ],
  "publicApiSurface": [
    "RssFeedService.GetEpisodesAsync()",
    "EpisodeParserService.ParseEpisode()",
    "ConsoleOutputService.ShowSumary()",
    "ConsoleOutputService.ShowError()",
    "RssEpisodeItem",
    "EpisodeParseResults"
  ]
}
